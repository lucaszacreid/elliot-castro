# Resend API key — get from resend.com
RESEND_API_KEY=re_YOUR_API_KEY_HERE

# Email address that receives all enquiry forms
CONTACT_EMAIL=elliot@elliotcastro.com

# Admin dashboard credentials
ADMIN_PASSWORD=your-secure-password-here
ADMIN_SECRET=your-random-32-character-secret-here

# SQLite database path (optional — defaults to ./data/enquiries.db)
# DATABASE_PATH=/absolute/path/to/enquiries.db
