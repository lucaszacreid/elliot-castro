# Turso database — create a database at turso.tech and copy these from the dashboard
TURSO_DATABASE_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Resend — get your API key at resend.com
RESEND_API_KEY=re_YOUR_API_KEY_HERE

# Email address that receives enquiry notification emails
CONTACT_EMAIL=elliot@elliotcastro.com

# Admin dashboard — set strong values before deploying
ADMIN_PASSWORD=your-secure-password-here
ADMIN_SECRET=your-random-64-character-hex-string-here
